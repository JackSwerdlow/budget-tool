{
  "name": "budget-tool",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "cross-env BUDGET_DB=data/budget.db PORT=8100 node --watch apps/api/src/index.ts",
    "dev:web": "npm -w @budget/web run dev",
    "dev:demo": "concurrently -k -n api,web -c blue,magenta \"npm:dev:demo:api\" \"npm:dev:web\"",
    "dev:demo:api": "cross-env BUDGET_DB=data/budget-demo.db PORT=8100 node --watch apps/api/src/index.ts",
    "build": "npm -w @budget/web run build",
    "start": "cross-env NODE_ENV=production BUDGET_DB=data/budget.db PORT=8100 node apps/api/src/index.ts",
    "start:demo": "cross-env NODE_ENV=production BUDGET_DB=data/budget-demo.db PORT=8100 node apps/api/src/index.ts",
    "seed:demo": "cross-env BUDGET_DB=data/budget-demo.db node apps/api/src/seed-demo.ts",
    "tauri:dev": "npm -w @budget/desktop run tauri dev",
    "tauri:build": "npm -w @budget/desktop run tauri build",
    "tauri:android:dev": "npm -w @budget/desktop run tauri android dev",
    "tauri:android:build": "npm -w @budget/desktop run tauri android build -- --apk -t aarch64",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^24.0.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=22.13"
  }
}
