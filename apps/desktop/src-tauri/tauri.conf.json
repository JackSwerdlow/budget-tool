{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Budget Tool",
  "version": "0.1.0",
  "identifier": "com.budgettool.desktop",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5001",
    "beforeDevCommand": "npm --prefix ../.. run dev:web",
    "beforeBuildCommand": "npm --prefix ../.. run build"
  },
  "app": {
    "windows": [
      {
        "title": "Budget Tool",
        "width": 1200,
        "height": 820,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
